# ============================================================
# AlphaSight — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# -----------------------------------------------------------
# Market Data — Polygon.io (primary)
# -----------------------------------------------------------
POLYGON_API_KEY=your_polygon_api_key_here

# -----------------------------------------------------------
# Trading — Alpaca
# -----------------------------------------------------------
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# -----------------------------------------------------------
# AI / LLM — OpenAI
# -----------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# -----------------------------------------------------------
# Database — PostgreSQL
# -----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://alphsight:alphsight@postgres:5432/alphsight

# -----------------------------------------------------------
# Cache / Real-time — Redis
# -----------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------
# Notifications — Discord (optional)
# -----------------------------------------------------------
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------
# Notifications — Email via SMTP
# -----------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alphsight@example.com

# -----------------------------------------------------------
# Notifications — Telegram
# -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------
# Notifications — Slack
# -----------------------------------------------------------
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------
# Notifications — Active Channels
# Comma-separated list: email,sms,discord,telegram,slack,push
# -----------------------------------------------------------
NOTIFICATION_CHANNELS=discord

# -----------------------------------------------------------
# General
# -----------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_PORT=8000
