# ============================================================
# AlphaSight — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ============================================================
# REQUIRED — the agent will not trade without these
# ============================================================

# Get yours at https://app.alpaca.markets (Live) or https://paper-alpaca.markets (Paper)
ALPACA_API_KEY=your_alpaca_api_key_here

# Found next to your API key in the Alpaca dashboard
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Paper trading default. Switch to https://api.alpaca.markets for live
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Get yours at https://polygon.io/dashboard (free tier works)
POLYGON_API_KEY=your_polygon_api_key_here

# ============================================================
# OPTIONAL — the agent works without these, but better with
# ============================================================

# Only needed for AI-powered sentiment. Get at https://platform.openai.com/api-keys
OPENAI_API_KEY=
